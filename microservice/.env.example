# =============================================================================
# SINAPSIS AI Microservice — Variables de entorno
# Copiar a .env y rellenar con valores reales. NO commitear .env.
# =============================================================================

# --- RabbitMQ ---
# URL AMQP completa con credenciales (requerida)
RABBITMQ_URL=amqp://user:password@localhost:5672/

# Cola de solicitudes de análisis
RABBITMQ_REQUEST_QUEUE=ai.analysis.requests

# Exchange donde se publican los resultados
RABBITMQ_RESULT_EXCHANGE=sinapsis.ai

# Routing key de resultados
RABBITMQ_RESULT_ROUTING_KEY=ai.analysis.result

# Mensajes en vuelo por worker (prefetch); mantener en 1 para inferencias pesadas
RABBITMQ_PREFETCH=1

# --- MONAI Bundles ---
# Directorio local de caché de bundles MONAI (no versionar pesos en git)
BUNDLE_CACHE_DIR=./.bundle_cache

# Fuente de descarga de bundles: monaihosting | huggingface
BUNDLE_SOURCE=monaihosting

# Tipos de análisis habilitados, separados por coma (requerida)
# Ejemplo: ct_spleen_segmentation
ALLOWED_ANALYSIS_TYPES=ct_spleen_segmentation

# --- Inferencia ---
# Dispositivo de cómputo: cpu | cuda | cuda:0 | cuda:1 ...
MODEL_DEVICE=cpu

# --- Almacenamiento de imágenes ---
# Backend de imágenes/artefactos (esquema URI, requerido)
# Ejemplo: s3 | file | gs
IMAGE_STORAGE_BACKEND=s3

# --- Logging ---
# Nivel de logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
